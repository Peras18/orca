# CONFIGURAÇÃO PROJETO ORCA - BASE MAINNET

# 1. AUTENTICAÇÃO (OBRIGATÓRIO)
# Coloca a tua chave privada da wallet aqui (sem 0x)
PRIVATE_KEY=sua_chave_privada_aqui

# 2. RPC & CONEXÃO (FAILOVER ATIVO)
# Se tiveres Alchemy, coloca a chave abaixo. O bot construirá os URLs automaticamente.
ALCHEMY_KEY=sua_chave_alchemy_aqui

# RPCs Adicionais (separados por vírgula)
# O bot usará wss://mainnet.base.org como fallback automático se estes falharem.
EXTRA_WSS_RPCS=wss://base-rpc.publicnode.com,wss://base.gateway.tenderly.co

# 3. MODOS DE OPERAÇÃO
# DRY_RUN=true: Apenas observa e audita oportunidades (Audit Mode)
# DRY_RUN=false: Tenta executar bundles reais (CUIDADO!)
DRY_RUN=true

# 4. PARÂMETROS DE ESTRATÉGIA
MIN_PROFIT_ETH=0.001
MAX_PATH_LENGTH=3
GAS_CAP_GWEI=50
PRIORITY_FEE_BASE_GWEI=1

# 5. EXECUÇÃO
# Endereço do teu contrato executor na Base Mainnet
EXECUTOR_ADDRESS=0x0000000000000000000000000000000000000000
